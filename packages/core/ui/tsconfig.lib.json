{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    // This library is consumed as source by Metro (a bundler), so use
    // bundler-style resolution (extensionless imports) instead of the
    // workspace-default nodenext (which would require ".js" extensions
    // that Metro cannot resolve to the real .ts/.tsx files).
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": []
}
